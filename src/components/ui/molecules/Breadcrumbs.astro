---
interface Props {
  items: Array<{ label: string; href?: string; current?: boolean }>;
}
const { items } = Astro.props;
---
<nav class="breadcrumbs" aria-label="Breadcrumb">
  {items.map((item, i) => (
    <>
      {i > 0 && <span class="sep" aria-hidden="true">/</span>}
      {item.current || (!item.href && i === items.length - 1)
        ? <span class="current" aria-current="page">{item.label}</span>
        : item.href
          ? <a href={item.href}>{item.label}</a>
          : <span>{item.label}</span>
      }
    </>
  ))}
</nav>

<style>
  .breadcrumbs {
    font-family: var(--f-mono);
    font-size: var(--fs-xs);
    color: var(--ink-3);
    margin: 0 0 var(--space-4);
    padding: 0;
    display: flex;
    gap: var(--space-2);
    align-items: center;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    list-style: none;
  }
  .sep {
    color: var(--ink-3);
    letter-spacing: 0;
  }
  a {
    color: var(--ink-3);
    text-decoration: none;
    cursor: pointer;
    transition: color var(--dur-fast) var(--ease);
  }
  a:hover {
    color: var(--ink);
  }
  a:focus-visible {
    outline: 2px solid var(--focus-ring);
    outline-offset: 2px;
  }
  .current {
    color: var(--ink);
    max-width: 60ch;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  @media (max-width: 480px) {
    .current {
      max-width: 30ch;
    }
  }
</style>
