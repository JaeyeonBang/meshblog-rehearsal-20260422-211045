---
interface TocItem {
  label: string;
  level?: 1 | 2;
  href?: string;
  active?: boolean;
}
interface Props {
  label: string;
  items?: TocItem[];
  mesh?: boolean;
}
const { label, items = [], mesh = false } = Astro.props;
---
<div class="toc">
  <div class="toc-label">{label}</div>
  {mesh ? (
    <slot />
  ) : items.length > 0 ? (
    <ul>
      {items.map((item) => (
        <li class:list={[item.active && 'active', item.level === 2 && 'l2']}>
          {item.href
            ? <a href={item.href}>{item.label}</a>
            : item.label
          }
        </li>
      ))}
    </ul>
  ) : (
    <slot />
  )}
</div>

<style>
  .toc {
    margin-bottom: 36px;
  }
  .toc-label {
    font-family: var(--f-mono);
    font-size: 10px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--ink);
    padding-bottom: 8px;
    margin-bottom: 10px;
    border-bottom: 1px solid var(--ink);
  }
  ul {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  li {
    font-family: var(--f-serif);
    font-size: 14px;
    padding: 5px 0;
    color: var(--ink-3);
    cursor: pointer;
    position: relative;
    padding-left: 18px;
    transition: color var(--dur-fast) var(--ease);
    line-height: 1.3;
  }
  li::before {
    content: "›";
    font-family: var(--f-mono);
    position: absolute;
    left: 0;
    color: var(--ink-4);
    font-size: 12px;
  }
  li.active {
    color: var(--ink);
    font-weight: 600;
  }
  li.active::before {
    color: var(--ink);
  }
  li:hover {
    color: var(--ink);
  }
  li.l2 {
    padding-left: 32px;
    font-size: 13px;
  }
  li.l2::before {
    left: 18px;
    content: "—";
  }
  a {
    color: inherit;
    text-decoration: none;
    display: block;
  }
  a:focus-visible {
    outline: 2px solid var(--focus-ring);
    outline-offset: 2px;
  }
</style>
