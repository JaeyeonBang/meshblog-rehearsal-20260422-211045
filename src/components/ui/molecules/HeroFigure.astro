---
interface Props {
  label?: string;
  src?: string;
  alt?: string;
}
const { label = 'hero · figure', src, alt } = Astro.props;
---
{src ? (
  <figure class="hero-figure hero-figure--img">
    <img src={src} alt={alt ?? label} loading="lazy" decoding="async" />
  </figure>
) : (
  <figure class="hero-figure" aria-label={label}>
    <span>{label}</span>
  </figure>
)}

<style>
  .hero-figure {
    border: 1px solid var(--ink);
    aspect-ratio: 16 / 7;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--f-mono);
    color: var(--ink);
    font-size: var(--fs-xs);
    margin: 0 0 48px;
    background:
      linear-gradient(135deg, transparent 49.5%, var(--ink) 49.5%, var(--ink) 50.5%, transparent 50.5%),
      linear-gradient(45deg, transparent 49.5%, var(--ink) 49.5%, var(--ink) 50.5%, transparent 50.5%),
      var(--paper);
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }
  .hero-figure span {
    background: var(--paper);
    padding: 4px 10px;
    border: 1px solid var(--ink);
  }
  .hero-figure--img {
    background: none;
    padding: 0;
  }
  .hero-figure--img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
</style>
