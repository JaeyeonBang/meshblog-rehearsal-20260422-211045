---
interface Props {
  tier: 'note' | 'concept' | 'global';
}
const { tier } = Astro.props;
---
<span class:list={['tier-badge', tier]}>
  {tier}
</span>

<style>
  .tier-badge {
    font-family: var(--f-mono);
    font-size: 9px;
    font-weight: 500;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    padding: 1px 6px;
    display: inline-block;
    line-height: 1.6;
  }
  .tier-badge.note {
    border: 1px solid var(--ink-5);
    color: var(--ink-3);
  }
  .tier-badge.concept {
    border: 1px solid var(--ink);
    color: var(--ink);
  }
  .tier-badge.global {
    background: var(--ink);
    color: var(--paper);
  }
</style>
