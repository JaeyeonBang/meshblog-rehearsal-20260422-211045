---
type InputType = 'text' | 'search' | 'email' | 'password' | 'url' | 'tel' | 'number';
interface Props {
  placeholder?: string;
  type?: InputType;
  value?: string;
  name?: string;
  id?: string;
  class?: string;
  withIcon?: boolean;
  [key: string]: unknown;
}
const { placeholder, type = 'text', value, name, id, class: className, withIcon = false, ...rest } = Astro.props;
---
{withIcon ? (
  <div class="search">
    <span class="ico">
      <svg width="14" height="14" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.8">
        <circle cx="7" cy="7" r="4.5"/>
        <path d="M10.3 10.3L13.5 13.5"/>
      </svg>
    </span>
    <input class:list={['input', className]} type={type} placeholder={placeholder} value={value} name={name} id={id} {...rest} />
  </div>
) : (
  <input class:list={['input', className]} type={type} placeholder={placeholder} value={value} name={name} id={id} {...rest} />
)}

<style>
  .input {
    font-family: var(--f-sans);
    font-size: 14px;
    width: 100%;
    padding: 10px 16px;
    border: 1px solid var(--ink);
    background: var(--paper);
    color: var(--ink);
    border-radius: var(--r-xs);
    outline: none;
    transition: background var(--dur-fast) var(--ease);
  }
  .input::placeholder {
    color: var(--ink-4);
  }
  .input:focus {
    background: var(--paper-2);
  }
  .input:focus-visible {
    outline: 2px solid var(--focus-ring);
    outline-offset: 2px;
  }
  .search {
    position: relative;
    display: flex;
    align-items: center;
  }
  .ico {
    position: absolute;
    left: 12px;
    color: var(--ink-3);
    pointer-events: none;
    display: flex;
  }
  .search .input {
    padding-left: 38px;
  }
</style>
