---
interface Props {
  variant?: 'new' | 'updated' | 'featured' | 'default';
  class?: string;
}
const { variant = 'default', class: className } = Astro.props;
---
<span class:list={['badge', variant !== 'default' && `badge--${variant}`, className]}>
  <slot />
</span>

<style>
  /* Base badge — mono eyebrow style */
  .badge {
    font-family: var(--f-mono);
    font-size: var(--fs-xs);
    font-weight: 500;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    padding: 2px 8px;
    border: 1px solid var(--ink);
    display: inline-block;
    line-height: 1.6;
    color: var(--ink-3);
  }

  /* new — published within last 7 days */
  .badge--new {
    border: none;
    border-bottom: 1px solid var(--ink);
    padding: 0 0 1px;
    background: transparent;
    color: var(--ink-3);
  }

  /* updated — updated within last 30 days */
  .badge--updated {
    border: none;
    border-bottom: 1px solid var(--ink-3);
    padding: 0 0 1px;
    background: transparent;
    color: var(--ink-3);
  }

  /* featured — editor's pick / featured content */
  .badge--featured {
    border: none;
    border-bottom: 1px solid var(--ink);
    padding: 0 0 1px;
    background: transparent;
    color: var(--ink-3);
  }
</style>
