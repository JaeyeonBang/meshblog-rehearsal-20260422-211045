---
import { withBase } from '../../../lib/url';
---
<footer class="footer">
  <div class="footer-box">
    <div class="footer-col">
      <div class="brand">meshblog</div>
      <div class="tagline">Obsidian vault로 키우고, 정적 사이트로 내보내는 2nd-brain 블로그.</div>
    </div>
    <div class="footer-col">
      <div class="ch">read</div>
      <a href={withBase('/posts')}>최신 posts</a>
      <a href={withBase('/posts/archive')}>아카이브</a>
      <a href={withBase('/tags')}>태그</a>
      <a href={withBase('/atom.xml')}>atom · rss</a>
    </div>
    <div class="footer-col">
      <div class="ch">explore</div>
      <a href={withBase('/graph')}>graph</a>
      <a href={withBase('/notes')}>notes</a>
      <a href={withBase('/graph?mode=concept')}>개념 클러스터</a>
      <a href={withBase('/random')}>random</a>
    </div>
    <div class="footer-col">
      <div class="ch">about</div>
      <a href={withBase('/about')}>만든 사람</a>
      <a href={withBase('/about#colophon')}>콜로폰</a>
      <a href="https://github.com" target="_blank" rel="noopener">github</a>
      <a href="mailto:hello@meshblog.dev">mailto</a>
    </div>
  </div>
  <div class="footer-legal">
    <span>© 2026 meshblog</span>
    <span>built with astro + sqlite</span>
  </div>
</footer>

<style>
  .footer {
    max-width: var(--w-page);
    margin: 0 auto;
    padding: 0 var(--space-8) 48px;
  }
  .footer-box {
    border-top: 3px solid var(--ink);
    border-bottom: 1px solid var(--ink);
    padding: 40px 0 36px;
    display: grid;
    grid-template-columns: 1.8fr 1fr 1fr 1fr;
    gap: var(--space-8);
  }
  @media (max-width: 780px) {
    .footer-box {
      grid-template-columns: 1fr 1fr;
    }
  }
  .footer-col .ch {
    font-family: var(--f-mono);
    font-size: 10px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--ink);
    margin-bottom: 14px;
    padding-bottom: 8px;
    border-bottom: 1px solid var(--rule-soft);
  }
  .footer-col a {
    font-family: var(--f-serif);
    font-size: var(--fs-base);
    color: var(--ink-2);
    padding: 4px 0;
    display: block;
    cursor: pointer;
    text-decoration: none;
    transition: color var(--dur-fast) var(--ease);
  }
  .footer-col a:hover {
    color: var(--ink);
    text-decoration: underline;
    text-underline-offset: 3px;
  }
  .footer-col a:focus-visible {
    outline: 2px solid var(--focus-ring);
    outline-offset: 2px;
  }
  .brand {
    font-family: var(--f-disp);
    font-size: 32px;
    font-weight: 600;
    margin-bottom: 12px;
    letter-spacing: -0.02em;
    line-height: 1;
  }
  .tagline {
    font-family: var(--f-serif);
    font-size: 14px;
    color: var(--ink-3);
    line-height: 1.55;
    font-style: italic;
    max-width: 34ch;
  }
  .footer-legal {
    font-family: var(--f-mono);
    font-size: 10px;
    color: var(--ink-3);
    padding: 18px 0;
    letter-spacing: 0.12em;
    display: flex;
    justify-content: space-between;
  }
</style>
