---
import { withBase } from '../../../lib/url';
// No props — global, opened via window.dispatchEvent(new Event('cmdk:open'))
---
<div class="cmdk-backdrop" id="cmdk-backdrop" role="dialog" aria-modal="true" aria-label="Search" aria-hidden="true">
  <div class="cmdk" id="cmdk-panel">
    <div class="search-box">
      <span class="ico" aria-hidden="true">
        <svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.8">
          <circle cx="7" cy="7" r="4.5"/>
          <path d="M10.3 10.3L13.5 13.5"/>
        </svg>
      </span>
      <input
        type="search"
        id="cmdk-input"
        placeholder="검색…"
        autocomplete="off"
        aria-label="Search"
      />
      <span class="kbd" aria-label="Press Escape to close">esc</span>
    </div>

    <div class="results" role="listbox" aria-label="Search results">
      <div class="group-head">
        <span>posts</span>
        <span class="c">4</span>
      </div>
      <a class="result" href={withBase('/posts/why-i-built-meshblog')} role="option">
        <span class="kind-badge post">post</span>
        <span class="t">왜 meshblog를 만들었나</span>
        <span class="m">7 min</span>
      </a>
      <a class="result" href={withBase('/posts/sqlite-is-all-you-need')} role="option">
        <span class="kind-badge post">post</span>
        <span class="t">SQLite is all you need</span>
        <span class="m">6 min</span>
      </a>

      <div class="group-head">
        <span>notes</span>
        <span class="c">14</span>
      </div>
      <a class="result" href={withBase('/notes/knowledge-graphs')} role="option">
        <span class="kind-badge note">note</span>
        <span class="t">knowledge-graphs</span>
        <span class="m">N / 09</span>
      </a>
      <a class="result" href={withBase('/notes/rag')} role="option">
        <span class="kind-badge note">note</span>
        <span class="t">rag — retrieval-augmented-generation</span>
        <span class="m">N / 10</span>
      </a>
    </div>

    <div class="footer" aria-hidden="true">
      <span><span class="kbd">↑↓</span> navigate</span>
      <span><span class="kbd">↵</span> open</span>
      <span><span class="kbd">esc</span> close</span>
    </div>
  </div>
</div>

<style>
  .cmdk-backdrop {
    position: fixed;
    inset: 0;
    /* Token-aware scrim: uses ink at low opacity so it reads on both light and dark backgrounds */
    background: color-mix(in srgb, var(--ink) 35%, transparent);
    z-index: 90;
    display: none;
    align-items: flex-start;
    justify-content: center;
    padding-top: 12vh;
  }
  .cmdk-backdrop.open {
    display: flex;
  }
  .cmdk {
    width: min(640px, calc(100vw - 32px));
    background: var(--paper);
    border: 1px solid var(--ink);
    overflow: hidden;
    display: flex;
    flex-direction: column;
    max-height: 76vh;
    box-shadow: var(--shadow-hard);
  }
  .search-box {
    padding: 14px 18px;
    display: flex;
    align-items: center;
    gap: 12px;
    border-bottom: 1px solid var(--ink);
  }
  .ico {
    color: var(--ink);
    display: flex;
    flex-shrink: 0;
  }
  .search-box input {
    font-family: var(--f-disp);
    font-size: var(--fs-xl);
    font-weight: 500;
    border: 0;
    background: transparent;
    outline: none;
    flex: 1;
    color: var(--ink);
    letter-spacing: -0.01em;
    width: 100%;
  }
  .search-box input::placeholder {
    color: var(--ink-4);
    font-weight: 400;
  }
  .search-box .kbd {
    margin-left: auto;
    flex-shrink: 0;
  }
  .results {
    flex: 1;
    overflow-y: auto;
    padding: 0;
  }
  .group-head {
    font-family: var(--f-mono);
    font-size: 10px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--ink-3);
    padding: 14px 18px 6px;
    background: var(--paper-2);
    border-top: 1px solid var(--rule-soft);
    border-bottom: 1px solid var(--rule-soft);
    display: flex;
    align-items: baseline;
    gap: 8px;
  }
  .group-head .c {
    margin-left: auto;
    color: var(--ink-4);
  }
  .result {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 11px 18px;
    cursor: pointer;
    border-bottom: 1px solid var(--rule-soft);
    transition: background var(--dur-fast) var(--ease);
    text-decoration: none;
    color: inherit;
  }
  .result:last-child {
    border-bottom: 0;
  }
  .result:hover,
  .result.active {
    background: var(--ink);
    color: var(--paper);
  }
  .result:hover .m,
  .result.active .m {
    color: var(--ink-5);
  }
  .result:hover .kind-badge,
  .result.active .kind-badge {
    background: var(--paper);
    color: var(--ink);
    border-color: var(--paper);
  }
  .result:focus-visible {
    outline: 2px solid var(--focus-ring);
    outline-offset: -2px;
  }
  .kind-badge {
    font-family: var(--f-mono);
    font-size: 10px;
    font-weight: 500;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    padding: 2px 8px;
    border: 1px solid var(--ink);
    display: inline-block;
    line-height: 1.6;
    flex-shrink: 0;
  }
  .kind-badge.post {
    background: var(--ink);
    color: var(--paper);
  }
  .kind-badge.note {
    background: var(--paper);
    color: var(--ink);
  }
  .t {
    font-family: var(--f-disp);
    font-size: var(--fs-md);
    font-weight: 500;
    flex: 1;
    letter-spacing: -0.005em;
  }
  .m {
    font-family: var(--f-mono);
    font-size: 10px;
    color: var(--ink-3);
    letter-spacing: 0.04em;
    flex-shrink: 0;
  }
  .footer {
    padding: 10px 18px;
    display: flex;
    gap: 16px;
    font-family: var(--f-mono);
    font-size: 10px;
    color: var(--ink-3);
    border-top: 1px solid var(--ink);
    background: var(--paper-2);
    letter-spacing: 0.04em;
  }
  .footer span {
    display: inline-flex;
    gap: 5px;
    align-items: center;
  }
  .kbd {
    font-family: var(--f-mono);
    font-size: 10px;
    padding: 2px 6px;
    color: var(--ink);
    background: var(--paper);
    border: 1px solid var(--ink-5);
    letter-spacing: 0.04em;
  }
</style>

<script>
  function initCmdK() {
    const bd = document.getElementById('cmdk-backdrop');
    const inp = document.getElementById('cmdk-input') as HTMLInputElement | null;
    if (!bd || !inp) return;

    function open() {
      bd!.classList.add('open');
      bd!.setAttribute('aria-hidden', 'false');
      setTimeout(() => inp!.focus(), 50);
    }

    function close() {
      bd!.classList.remove('open');
      bd!.setAttribute('aria-hidden', 'true');
      inp!.value = '';
    }

    document.addEventListener('keydown', (e) => {
      if ((e.metaKey || e.ctrlKey) && e.key === 'k') {
        e.preventDefault();
        bd!.classList.contains('open') ? close() : open();
      }
      if (e.key === 'Escape' && bd!.classList.contains('open')) {
        close();
      }
    });

    window.addEventListener('cmdk:open', open);

    bd.addEventListener('click', (e) => {
      if (e.target === bd) close();
    });
  }

  // Run on initial load and after Astro view transitions
  document.addEventListener('DOMContentLoaded', initCmdK);
  document.addEventListener('astro:page-load', initCmdK);
</script>
