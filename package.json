{
  "name": "meshblog",
  "type": "module",
  "version": "0.0.1",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "NODE_ENV=production astro build",
    "preview": "astro preview",
    "astro": "astro",
    "test": "vitest run",
    "test:watch": "vitest",
    "build-index": "tsx scripts/build-index.ts",
    "generate-qa": "tsx scripts/generate-qa.ts",
    "build-qa": "tsx scripts/generate-qa.ts",
    "build-qa:fresh": "tsx scripts/generate-qa.ts --clear",
    "export-graph": "tsx scripts/export-graph.ts",
    "build-backlinks": "tsx scripts/build-backlinks.ts",
    "build-tokens": "tsx scripts/build-tokens.ts",
    "build-manifest": "tsx scripts/build-manifest.ts",
    "build-og": "tsx scripts/build-og.ts",
    "build-rss": "tsx scripts/build-rss.ts",
    "audit-report": "tsx scripts/audit-report.ts",
    "build-all": "bun run build-index && bun run generate-qa && bun run export-graph && bun run build-manifest && bun run build-tokens && bun run build",
    "build:fixture": "FIXTURE_ONLY=1 bun run build-index && bun run export-graph && bun run build",
    "setup": "cp -n .env.example .env.local 2>/dev/null; mkdir -p .data .data/qa/note .data/qa/concept .data/qa/global content/notes content/posts; echo 'setup done'",
    "init": "bun run scripts/init.ts",
    "new-post": "tsx scripts/new-post.ts",
    "build-backlinks-if-exists": "[ -f scripts/build-backlinks.ts ] && tsx scripts/build-backlinks.ts || echo '[refresh] build-backlinks.ts not present yet, skipping'",
    "refresh": "bun run build-tokens && bun run build-index && bun run build-backlinks-if-exists && bun run preview",
    "pretest:e2e": "FIXTURE_ONLY=1 bun run build-index && bun run export-graph && bunx tsx tests/e2e/_seed.ts && bun run build",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "@astrojs/check": "^0.9.8",
    "@astrojs/react": "^5.0.3",
    "@resvg/resvg-js": "^2.6.2",
    "astro": "^6.1.6",
    "better-sqlite3": "^12.9.0",
    "d3-drag": "^3.0.0",
    "d3-force": "^3.0.0",
    "d3-selection": "^3.0.0",
    "d3-zoom": "^3.0.0",
    "dotenv": "^17.4.2",
    "fuse.js": "^7.3.0",
    "graphology": "^0.26.0",
    "graphology-communities-louvain": "^2.0.2",
    "graphology-metrics": "^2.4.0",
    "gray-matter": "^4.0.3",
    "openai": "^6.34.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-markdown": "^10.1.0",
    "rehype-raw": "^7.0.0",
    "remark-gfm": "^4.0.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/d3-drag": "^3.0.7",
    "@types/d3-force": "^3.0.10",
    "@types/d3-selection": "^3.0.11",
    "@types/d3-zoom": "^3.0.8",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "axe-core": "^4.11.3",
    "happy-dom": "^20.9.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.4"
  }
}